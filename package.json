{
  "name": "markdown-nice",
  "type": "module",
  "version": "2.0.0",
  "private": false,
  "packageManager": "pnpm@11.7.0",
  "description": "A Markdown editor with the function of style edition, built with Nuxt and antfu tooling",
  "author": "mdnice",
  "license": "GPL-3.0",
  "homepage": "https://mdnice.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/mdnice/markdown-nice"
  },
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/Lib.js"
    }
  },
  "main": "lib/Lib.js",
  "module": "lib/Lib.js",
  "typings": "./lib/index.d.ts",
  "files": [
    "app",
    "lib",
    "public"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "nuxi dev",
    "build": "nuxi build",
    "generate": "nuxi generate",
    "preview": "nuxi preview",
    "lint": "eslint . --fix",
    "test": "vitest",
    "typecheck": "nuxi typecheck",
    "publish:npm": "cross-env NODE_ENV=production && rm -rf lib && mkdir lib && cross-env BABEL_ENV=production npx babel src --out-dir lib --copy-files",
    "prepare": "npx simple-git-hooks || true"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.5",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/markdown": "^1.6.4",
    "@nuxt/ui": "^4.0.0",
    "@nuxtjs/color-mode": "^3.5.2",
    "@pinia/nuxt": "^0.11.0",
    "@sitdown/juejin": "^1.1.1",
    "@sitdown/wechat": "^1.1.1",
    "@sitdown/zhihu": "^1.1.1",
    "@vue/test-utils": "^2.4.6",
    "@vueuse/core": "^13.0.0",
    "diff-match-patch": "^1.0.5",
    "highlight.js": "^11.11.0",
    "juice": "^11.0.1",
    "lodash-es": "^4.17.21",
    "markdown-it": "^14.1.0",
    "markdown-it-implicit-figures": "^0.12.0",
    "markdown-it-katex": "^2.0.3",
    "markdown-it-ruby": "^0.1.1",
    "markdown-it-table-of-contents": "^0.8.0",
    "mathjax": "^3.2.2",
    "pinia": "^3.0.2",
    "prettier": "^3.5.3",
    "sitdown": "^1.1.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.0.0",
    "@nuxt/devtools": "^2.0.0",
    "@unocss/nuxt": "^66.7.4",
    "happy-dom": "^17.4.4",
    "lint-staged": "^15.5.2",
    "nuxt": "^4.0.0",
    "simple-git-hooks": "^2.12.1",
    "typescript": "^5.8.3",
    "unocss": "^66.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  }
}
